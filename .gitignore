# ==========================================
# 依賴套件（絕對不要推上 Git）
# ==========================================
node_modules/
server/node_modules/
client/node_modules/

# ==========================================
# 前端打包產物（由 Render 線上打包即可）
# ==========================================
dist/
client/dist/
build/
.vite/

# ==========================================
# 本地產生的資料與歷史紀錄（避免隱私外洩與檔案污染）
# ==========================================
server/data/
data/
*.json.bak

# ==========================================
# 日誌與暫存檔
# ==========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# 環境變數設定檔（敏感資訊）
# ==========================================
.env
.env.local
.env.production
server/.env
client/.env

# ==========================================
# 作業系統系統檔
# ==========================================
.DS_Store
Thumbs.db